<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Quantity_Cannot_Be_Negative</fullName>
    <active>true</active>
    <errorConditionFormula>AvailableQuantity__c &lt; 0</errorConditionFormula>
    <errorDisplayField>AvailableQuantity__c</errorDisplayField>
    <errorMessage>Available quantity cannot be negative.</errorMessage>
</ValidationRule>

